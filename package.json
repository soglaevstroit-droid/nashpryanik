{
  "name": "stroit-platform",
  "version": "0.1.0",
  "private": true,
  "description": "Development platform foundation for СТРОИТ.РФ.",
  "workspaces": [
    "apps/backend"
  ],
  "scripts": {
    "format:check": "prettier --check \"README.md\" \"LOCAL_VERIFICATION_CHECKLIST.md\" \".github/**/*.yml\" \"apps/**/*.{json,md,ts,yaml}\" \"packages/**/*.md\" \"infra/**/*.{md,yml}\" \"scripts/**/*.{mjs,md}\" \"docs/**/*.md\" \"*.{json,mjs}\" \".*.jsonc\"",
    "lint": "eslint .",
    "lint:md": "markdownlint-cli2 \"README.md\" \"LOCAL_VERIFICATION_CHECKLIST.md\" \"apps/**/*.md\" \"packages/**/*.md\" \"infra/**/*.md\" \"scripts/**/*.md\" \"docs/**/*.md\" \"!**/node_modules/**\"",
    "lint:yaml": "node scripts/validate-yaml.mjs",
    "backend:dev": "npm run start:dev -w @stroit/backend",
    "backend:build": "npm run build -w @stroit/backend",
    "backend:lint": "npm run lint -w @stroit/backend",
    "backend:test": "npm run test -w @stroit/backend",
    "backend:db:check": "npm run db:check -w @stroit/backend",
    "backend:bootstrap-demo-worker": "npm run bootstrap:demo-worker -w @stroit/backend",
    "demo:dev": "node apps/demo/server.mjs",
    "prisma:generate": "node --env-file=.env apps/backend/node_modules/prisma/build/index.js generate --schema apps/backend/prisma/schema.prisma",
    "prisma:migrate": "node --env-file=.env apps/backend/node_modules/prisma/build/index.js migrate dev --schema apps/backend/prisma/schema.prisma",
    "prisma:studio": "node --env-file=.env apps/backend/node_modules/prisma/build/index.js studio --schema apps/backend/prisma/schema.prisma",
    "test": "npm run backend:test"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@types/node": "^22.10.7",
    "eslint": "^9.18.0",
    "markdownlint-cli2": "^0.17.2",
    "prettier": "^3.4.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0",
    "yaml": "^2.7.0"
  }
}
