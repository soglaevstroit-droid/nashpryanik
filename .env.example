# СТРОИТ.РФ development environment example.
# Copy to .env when local overrides are needed. Values here are safe defaults for local development.

# Project
COMPOSE_PROJECT_NAME=stroit
ENVIRONMENT=development

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=stroit_dev
POSTGRES_USER=stroit
POSTGRES_PASSWORD=stroit_dev_password
DATABASE_URL=postgresql://stroit:stroit_dev_password@localhost:5432/stroit_dev?schema=public

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# MinIO
MINIO_HOST=localhost
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ROOT_USER=stroit_minio
MINIO_ROOT_PASSWORD=stroit_minio_password
MINIO_DEFAULT_BUCKET=stroit-dev
MINIO_USE_SSL=false

# Local backend
BACKEND_HOST=localhost
BACKEND_PORT=3000
API_PREFIX=/api/v1
JWT_SECRET=stroit-development-jwt-secret-change-before-production

# Local demo frontend and disposable demo account
DEMO_PORT=3100
DEMO_BACKEND_URL=http://localhost:3000
DEMO_WORKER_NAME=Илья Н.
DEMO_WORKER_EMAIL=ilya
DEMO_WORKER_PASSWORD=11223344

# Future mobile reserved values. Mobile app code is intentionally not implemented in this mission.
APP_NAME=СТРОИТ.РФ
APP_ENV=development

# Production backup preparation. Replace these placeholders only in the ignored local .env.
# The preparation command never connects to this host and never creates a database dump.
BACKUP_SSH_HOST=production.example.invalid
BACKUP_SSH_PORT=22
BACKUP_SSH_USER=backup
BACKUP_DATABASE_HOST=127.0.0.1
BACKUP_DATABASE_PORT=5432
BACKUP_DATABASE_NAME=stroit
BACKUP_DATABASE_USER=stroit_backup
BACKUP_DIRECTORY=backup
