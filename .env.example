# СТРОИТ.РФ development environment example.
# Copy to .env when local overrides are needed. Values here are safe defaults for local development.

# Project
COMPOSE_PROJECT_NAME=stroit
ENVIRONMENT=development

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=stroit_dev
POSTGRES_USER=stroit
POSTGRES_PASSWORD=stroit_dev_password
DATABASE_URL=postgresql://stroit:stroit_dev_password@localhost:5432/stroit_dev?schema=public

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# MinIO
MINIO_HOST=localhost
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ROOT_USER=stroit_minio
MINIO_ROOT_PASSWORD=stroit_minio_password
MINIO_DEFAULT_BUCKET=stroit-dev
MINIO_USE_SSL=false

# Local backend
BACKEND_HOST=localhost
BACKEND_PORT=3000
API_PREFIX=/api/v1
JWT_SECRET=stroit-development-jwt-secret-change-before-production

# Local demo frontend and disposable demo account
DEMO_PORT=3100
DEMO_BACKEND_URL=http://localhost:3000
DEMO_WORKER_NAME=Илья
DEMO_WORKER_EMAIL=ilya.demo@stroit.local
DEMO_WORKER_PASSWORD=stroit_demo_password

# Future mobile reserved values. Mobile app code is intentionally not implemented in this mission.
APP_NAME=СТРОИТ.РФ
APP_ENV=development
