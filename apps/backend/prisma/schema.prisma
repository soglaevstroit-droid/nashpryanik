generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum EventType {
  USER_CREATED
  USER_UPDATED
  USER_ROLE_CHANGED
  USER_ACTIVATED
  USER_DEACTIVATED
  USER_LOGGED_IN
  USER_LOGGED_OUT
  SESSION_STARTED
  SESSION_FINISHED
  WORK_SHIFT_STARTED
  WORK_SHIFT_PAUSED
  WORK_SHIFT_RESUMED
  WORK_SHIFT_FINISHED
  OBJECT_CREATED
  OBJECT_UPDATED
  OBJECT_ARCHIVED
  FLOOR_CREATED
  FLOOR_UPDATED
  ROOM_CREATED
  ROOM_UPDATED
  ROOM_COMPLETED
  TASK_CREATED
  TASK_UPDATED
  TASK_ASSIGNED
  TASK_ACCEPTED
  TASK_STARTED
  TASK_PAUSED
  TASK_SENT_TO_REVIEW
  TASK_COMPLETED
  TASK_CANCELLED
  TASK_PRIORITY_CHANGED
  TASK_ACCESS_OPENED
  TASK_ACCESS_CLOSED
  TASK_DELETED
  STEP_CREATED
  STEP_STARTED
  STEP_COMPLETED
  STEP_REOPENED
  STEP_CANCELLED
  PHOTO_CAPTURED
  PHOTO_UPLOADED
  HELP_REQUEST
  MANAGER_REPLY
  PHOTO_APPROVED
  PHOTO_REJECTED
  PHOTO_DELETED
  INSPECTION_STARTED
  INSPECTION_APPROVED
  INSPECTION_REJECTED
  COINS_GRANTED
  COINS_REVOKED
  BONUS_GRANTED
  PAYMENT_CREATED
  PAYMENT_APPROVED
  PAYMENT_COMPLETED
  AI_ANALYSIS_CREATED
  AI_RECOMMENDATION_CREATED
  AI_WARNING_CREATED
  NOTIFICATION_SENT
  NOTIFICATION_READ
  SYSTEM_ERROR
  SYSTEM_WARNING
  SYSTEM_UPDATED
  PROCESS_CREATED
  PROCESS_STARTED
  PROCESS_PAUSED
  PROCESS_RESUMED
  PROCESS_COMPLETED
  PROCESS_CANCELLED
}

enum ProcessStatus {
  CREATED
  ACTIVE
  PAUSED
  COMPLETED
  CANCELLED
}

enum Role {
  CREATOR
  DIRECTOR
  FINANCE
  ANALYST
  FOREMAN
  WORKER
  PARTNER
}

enum ShiftAccrualStatus {
  ACTIVE
  PENDING_APPROVAL
  APPROVED
  REJECTED
}

enum OvertimeDecision {
  PENDING
  APPROVED
  ADJUSTED
  REJECTED
}

enum WorkShiftStatus {
  NOT_STARTED
  ACTIVE
  FINISHED
}

enum TaskStatus {
  CREATED
  ASSIGNED
  ACCEPTED
  IN_PROGRESS
  PAUSED
  ON_REVIEW
  COMPLETED
  CANCELLED
}

enum TaskMessageKind {
  PAUSE_REQUEST
  HELP_REQUEST
  MANAGER_REPLY
  TASK_UPDATED
}

enum ManagerDecision {
  CONTINUE
  STOP
}

enum TaskPriority {
  LOW
  NORMAL
  HIGH
  CRITICAL
  URGENT
}

enum TaskAccessStatus {
  OPEN
  CLOSED
}

enum TaskStepStatus {
  CREATED
  IN_PROGRESS
  COMPLETED
  REOPENED
  CANCELLED
}

enum ArtifactType {
  PHOTO
}

enum WorkShiftPhotoType {
  START
  FINISH
}

enum ArtifactSource {
  DIRECT_CAMERA_CAPTURE
}

model Event {
  id             String     @id @default(uuid())
  type           EventType
  actorId        String?
  entityType     String?
  entityId       String?
  objectId       String?
  taskId         String?
  taskStepId     String?
  workShiftId    String?
  idempotencyKey String?    @unique
  payload        Json
  metadata       Json?
  createdAt      DateTime   @default(now())
  artifacts      Artifact[]

  @@index([type])
  @@index([actorId])
  @@index([actorId, createdAt, id])
  @@index([taskId])
  @@index([workShiftId])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("events")
}

model ConstructionObject {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tasks     Task[]

  @@index([isActive, sortOrder])
  @@map("construction_objects")
}

model Process {
  id          String        @id @default(uuid())
  type        String
  status      ProcessStatus @default(CREATED)
  title       String
  description String?
  startedAt   DateTime?
  finishedAt  DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([type])
  @@index([status])
  @@index([createdAt])
  @@map("processes")
}

model User {
  id                      String   @id @default(uuid())
  email                   String   @unique
  passwordHash            String
  role                    Role
  name                    String?
  isActive                Boolean  @default(true)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
  openingBalanceCoinUnits Int      @default(0)

  @@index([role])
  @@index([isActive])
  @@map("users")
}

model WorkShift {
  id         String           @id @default(uuid())
  userId     String
  processId  String?
  status     WorkShiftStatus  @default(ACTIVE)
  startedAt  DateTime
  finishedAt DateTime?
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
  photos     WorkShiftPhoto[]
  accrual    ShiftAccrual?

  @@index([userId])
  @@index([status])
  @@index([startedAt])
  @@index([processId])
  @@map("work_shifts")
}

model ShiftAccrual {
  id                          String             @id @default(uuid())
  workShiftId                 String             @unique
  workerId                    String
  status                      ShiftAccrualStatus @default(ACTIVE)
  durationSeconds             Int                @default(0)
  standardDurationSeconds     Int                @default(0)
  overtimeSeconds             Int                @default(0)
  calculatedStandardCoinUnits Int                @default(0)
  standardCoinUnits           Int                @default(0)
  calculatedOvertimeCoinUnits Int                @default(0)
  analystFinalOvertimeUnits   Int?
  overtimeDecision            OvertimeDecision   @default(PENDING)
  analystComment              String?
  reviewedByUserId            String?
  reviewedAt                  DateTime?
  approvedByUserId            String?
  approvedAt                  DateTime?
  rejectionReason             String?
  createdAt                   DateTime           @default(now())
  updatedAt                   DateTime           @updatedAt
  workShift                   WorkShift          @relation(fields: [workShiftId], references: [id], onDelete: Restrict)

  @@index([workerId, status])
  @@index([status, createdAt])
  @@index([overtimeDecision, createdAt])
  @@map("shift_accruals")
}

model Task {
  id                  String              @id @default(uuid())
  title               String
  description         String?
  location            String?
  status              TaskStatus          @default(CREATED)
  priority            TaskPriority        @default(NORMAL)
  accessStatus        TaskAccessStatus    @default(OPEN)
  position            Int                 @default(1)
  creatorId           String
  assigneeId          String?
  processId           String
  objectId            String?
  completedAt         DateTime?
  deletedAt           DateTime?
  deletedByUserId     String?
  deletionReason      String?
  creationOperationId String?             @unique
  isWorkBlocked       Boolean             @default(false)
  workBlockedAt       DateTime?
  workBlockedByUserId String?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  object              ConstructionObject? @relation(fields: [objectId], references: [id], onDelete: Restrict)
  steps               TaskStep[]
  messages            TaskMessage[]

  @@index([status])
  @@index([priority])
  @@index([creatorId])
  @@index([assigneeId])
  @@index([assigneeId, status])
  @@index([assigneeId, deletedAt, position])
  @@index([objectId])
  @@index([processId])
  @@index([createdAt])
  @@map("tasks")
}

model TaskMessage {
  id          String           @id @default(uuid())
  taskId      String
  taskStepId  String?
  senderId    String
  recipientId String?
  parentId    String?
  kind        TaskMessageKind
  body        String
  decision    ManagerDecision?
  readAt      DateTime?
  createdAt   DateTime         @default(now())
  task        Task             @relation(fields: [taskId], references: [id], onDelete: Restrict)

  @@index([taskId, createdAt])
  @@index([senderId, createdAt])
  @@index([recipientId, createdAt])
  @@index([parentId])
  @@map("task_messages")
}

model TaskStep {
  id                    String         @id @default(uuid())
  taskId                String
  title                 String
  description           String?
  status                TaskStepStatus @default(CREATED)
  order                 Int
  startedAt             DateTime?
  completedAt           DateTime?
  completedByUserId     String?
  minimumPhotoCount     Int            @default(2)
  completionOperationId String?        @unique
  deletedAt             DateTime?
  deletedByUserId       String?
  deletionReason        String?
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt
  task                  Task           @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@index([taskId, deletedAt, order])
  @@index([status])
  @@index([order])
  @@index([createdAt])
  @@map("task_steps")
}

model Artifact {
  id               String          @id @default(uuid())
  type             ArtifactType    @default(PHOTO)
  eventId          String
  taskId           String?
  taskStepId       String?
  workShiftId      String?
  uploadedBy       String
  storageKey       String
  originalFileName String
  mimeType         String
  fileSize         Int
  createdAt        DateTime        @default(now())
  workShiftPhoto   WorkShiftPhoto?
  event            Event           @relation(fields: [eventId], references: [id], onDelete: Restrict)

  @@index([type])
  @@index([eventId])
  @@index([taskId])
  @@index([taskStepId])
  @@index([workShiftId])
  @@index([uploadedBy])
  @@index([createdAt])
  @@map("artifacts")
}

model WorkShiftPhoto {
  id          String             @id @default(uuid())
  workShiftId String
  artifactId  String             @unique
  type        WorkShiftPhotoType
  capturedAt  DateTime
  receivedAt  DateTime           @default(now())
  source      ArtifactSource
  timezone    String
  width       Int
  height      Int
  operationId String             @unique
  createdAt   DateTime           @default(now())

  workShift WorkShift @relation(fields: [workShiftId], references: [id], onDelete: Cascade)
  artifact  Artifact  @relation(fields: [artifactId], references: [id], onDelete: Restrict)

  @@unique([workShiftId, type])
  @@index([workShiftId])
  @@index([artifactId])
  @@index([type])
  @@index([capturedAt])
  @@map("work_shift_photos")
}
