generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum EventType {
  USER_CREATED
  USER_UPDATED
  USER_ROLE_CHANGED
  USER_ACTIVATED
  USER_DEACTIVATED
  USER_LOGGED_IN
  USER_LOGGED_OUT
  SESSION_STARTED
  SESSION_FINISHED
  WORK_SHIFT_STARTED
  WORK_SHIFT_PAUSED
  WORK_SHIFT_RESUMED
  WORK_SHIFT_FINISHED
  OBJECT_CREATED
  OBJECT_UPDATED
  OBJECT_ARCHIVED
  FLOOR_CREATED
  FLOOR_UPDATED
  ROOM_CREATED
  ROOM_UPDATED
  ROOM_COMPLETED
  TASK_CREATED
  TASK_UPDATED
  TASK_ASSIGNED
  TASK_ACCEPTED
  TASK_STARTED
  TASK_COMPLETED
  TASK_CANCELLED
  STEP_CREATED
  STEP_STARTED
  STEP_COMPLETED
  STEP_REOPENED
  PHOTO_CAPTURED
  PHOTO_UPLOADED
  PHOTO_APPROVED
  PHOTO_REJECTED
  PHOTO_DELETED
  INSPECTION_STARTED
  INSPECTION_APPROVED
  INSPECTION_REJECTED
  COINS_GRANTED
  COINS_REVOKED
  BONUS_GRANTED
  PAYMENT_CREATED
  PAYMENT_APPROVED
  PAYMENT_COMPLETED
  AI_ANALYSIS_CREATED
  AI_RECOMMENDATION_CREATED
  AI_WARNING_CREATED
  NOTIFICATION_SENT
  NOTIFICATION_READ
  SYSTEM_ERROR
  SYSTEM_WARNING
  SYSTEM_UPDATED
  PROCESS_CREATED
  PROCESS_STARTED
  PROCESS_PAUSED
  PROCESS_RESUMED
  PROCESS_COMPLETED
  PROCESS_CANCELLED
}

enum ProcessStatus {
  CREATED
  ACTIVE
  PAUSED
  COMPLETED
  CANCELLED
}

model Event {
  id         String    @id @default(uuid())
  type       EventType
  actorId    String?
  entityType String?
  entityId   String?
  payload    Json
  metadata   Json?
  createdAt  DateTime  @default(now())

  @@index([type])
  @@index([actorId])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("events")
}

model Process {
  id          String        @id @default(uuid())
  type        String
  status      ProcessStatus @default(CREATED)
  title       String
  description String?
  startedAt   DateTime?
  finishedAt  DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([type])
  @@index([status])
  @@index([createdAt])
  @@map("processes")
}
