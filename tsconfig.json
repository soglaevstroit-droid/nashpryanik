{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true
  },
  "include": ["apps/**/*.ts", "packages/**/*.ts", "*.config.mjs"],
  "exclude": ["node_modules", "dist", "build"]
}
